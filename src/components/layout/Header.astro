---
import TacticalCTA from '../ui/TacticalCTA.astro';
---
<header class="fixed top-0 w-full z-50 bg-zinc-950/80 backdrop-blur border-b border-zinc-800/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <!-- Monochromatic Logo -->
      <a href="/" aria-label="Aptus Home" class="focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:outline-none rounded">
        <svg width="120" height="40" viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-zinc-100">
          <path d="M18.8 17.5l-6-10.5-6 10.5h12zm-6-15l12 21h-4.5l-2.6-4.5h-9.8L5.3 23.5H.8l12-21z" fill="currentColor" />
          <text x="35" y="24" fill="currentColor" font-size="22" font-weight="700" font-family="Inter, sans-serif" letter-spacing="0.05em">Aptus</text>
        </svg>
      </a>

      <div class="w-full sm:w-auto flex justify-center">
        <TacticalCTA />
      </div>
    </div>
  </div>
</header>
