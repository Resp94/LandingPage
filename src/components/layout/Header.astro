---
import TacticalCTA from '../ui/TacticalCTA.astro';
---

<header class="fixed top-0 z-50 w-full border-b border-[var(--color-grid-subtle)] bg-surface-primary/80 backdrop-blur">
  <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <a href="/" aria-label="Aptus Home" class="flex items-center gap-3 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
        <img src="/logo.png" alt="Aptus Flow" class="h-16 w-auto object-contain" />
        <span class="text-2xl font-semibold tracking-tight text-[var(--color-text-primary)]">Aptus</span>
      </a>

      <div class="flex w-full justify-center sm:w-auto">
        <TacticalCTA />
      </div>
    </div>
  </div>
</header>
