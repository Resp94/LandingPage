---
import TacticalCTA from '../ui/TacticalCTA.astro';
---
<header class="fixed top-0 w-full z-50 bg-surface-primary/80 backdrop-blur border-b border-surface-tertiary/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <!-- Logo -->
      <a href="/" aria-label="Aptus Home" class="flex items-center gap-3 focus-visible:ring-2 focus-visible:ring-accent focus-visible:outline-none rounded">
        <img src="/logo.png" alt="Aptus Flow" class="h-16 w-auto object-contain" />
        <span class="text-2xl font-bold text-white tracking-tight">Aptus</span>
      </a>

      <div class="w-full sm:w-auto flex justify-center">
        <TacticalCTA />
      </div>
    </div>
  </div>
</header>
