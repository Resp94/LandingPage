---
import FormEmbed from './FormEmbed.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Formulario de Diagnostico',
  description = 'Complete os dados para prosseguirmos com a sua avaliacao',
} = Astro.props;
---

<dialog
  id="diagnostic-modal"
  aria-labelledby="diagnostic-modal-title"
  aria-describedby="diagnostic-modal-description"
  aria-modal="true"
  role="dialog"
  class="backdrop:bg-surface-primary/80 backdrop:backdrop-blur-xl m-auto mx-auto max-h-[90vh] min-h-[400px] w-[calc(100vw-2rem)] max-w-xl translate-y-2 overflow-y-auto rounded-2xl border border-[var(--color-border-subtle)] bg-surface-primary p-0 text-[var(--color-text-primary)] opacity-0 shadow-2xl transition-all duration-300 ease-out open:translate-y-0 open:opacity-100 motion-reduce:transition-none"
>
  <div class="relative flex w-full flex-col p-6 sm:p-8">
    <div class="mb-6 pr-8">
      <h2 id="diagnostic-modal-title" class="title-font text-xl font-medium tracking-tight text-[var(--color-text-primary)]">
        {title}
      </h2>
      <p id="diagnostic-modal-description" class="mt-1 text-sm text-[var(--color-text-secondary)]">
        {description}
      </p>
    </div>

    <button
      type="button"
      id="close-diagnostic-modal"
      aria-label="Fechar formulario de diagnostico"
      class="absolute right-4 top-4 z-10 rounded-lg p-2 text-[var(--color-text-meta)] transition-colors hover:bg-[var(--color-surface-tertiary)] hover:text-[var(--color-text-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface-primary md:right-6 md:top-6"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        class="h-5 w-5"
      >
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>

    <div class="relative flex min-h-[500px] w-full flex-1 items-stretch justify-center rounded-xl p-0 md:p-2">
      <div id="form-view" class="relative z-10 flex w-full items-stretch justify-center bg-surface-primary opacity-100 transition-opacity duration-300 ease-out">
        <FormEmbed />
      </div>

      <div id="success-view" role="status" aria-live="polite" class="pointer-events-none absolute inset-x-0 inset-y-0 z-20 hidden h-full w-full flex-col items-center justify-center bg-surface-primary p-6 text-center opacity-0 transition-opacity duration-300 ease-out sm:p-8">
        <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full border border-accent/20 bg-accent/10">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-accent"
            aria-hidden="true"
          >
            <path d="M20 6 9 17l-5-5" />
          </svg>
        </div>

        <h3 class="title-font mb-3 text-2xl font-medium tracking-tight text-[var(--color-text-primary)]">
          Analisando seu ecossistema...
        </h3>

        <p class="mx-auto mb-8 max-w-sm text-base text-[var(--color-text-secondary)]">
          Seu perfil foi enviado ao nucleo de Engenharia Aptus. Tempo de resposta projetado: 24h uteis.
        </p>

        <button
          type="button"
          id="success-close-btn"
          aria-label="Concluir e fechar"
          class="rounded-lg border border-[var(--color-border-subtle)] bg-transparent px-6 py-3 text-sm font-medium text-[var(--color-text-secondary)] transition-colors hover:border-[var(--color-border-subtle)] hover:bg-surface-secondary hover:text-[var(--color-text-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface-primary"
        >
          Fechar
        </button>
      </div>
    </div>
  </div>
</dialog>

<script>
  const root = document.documentElement;
  const bootstrapOpenDetailKey = '__diagnosticModalBootstrap';

  async function initModal() {
    if (root.dataset.diagnosticModalInitDone === 'true') return;
    root.dataset.diagnosticModalInitDone = 'true';

    const { setupModalListener } = await import('../../scripts/modal');
    setupModalListener();
  }

  function scheduleIdleInit() {
    if (root.dataset.diagnosticModalIdleInitScheduled === 'true') return;
    root.dataset.diagnosticModalIdleInitScheduled = 'true';

    const runInit = () => {
      void initModal();
    };
    const requestIdle = globalThis.requestIdleCallback;

    if (typeof requestIdle === 'function') {
      requestIdle(runInit, { timeout: 2000 });
      return;
    }

    globalThis.setTimeout(runInit, 1200);
  }

  function initWhenVisible() {
    const dialog = document.getElementById('diagnostic-modal');
    if (!dialog) return;

    if (!('IntersectionObserver' in window)) {
      void initModal();
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          void initModal();
          observer.disconnect();
        }
      },
      {
        root: null,
        threshold: 0.01,
      }
    );

    observer.observe(dialog);
    scheduleIdleInit();
  }

  function ensureInitOnFirstOpen(event: Event) {
    const customEvent = event as CustomEvent<Record<string, unknown> | null>;
    const isBootstrapReplay =
      customEvent instanceof CustomEvent &&
      typeof customEvent.detail === 'object' &&
      customEvent.detail !== null &&
      customEvent.detail[bootstrapOpenDetailKey] === true;

    if (isBootstrapReplay) return;
    if (root.dataset.diagnosticModalInitDone === 'true') return;

    event.preventDefault();
    event.stopImmediatePropagation();

    void initModal().then(() => {
      document.dispatchEvent(
        new CustomEvent('open-diagnostic', {
          bubbles: true,
          cancelable: true,
          detail: { [bootstrapOpenDetailKey]: true },
        })
      );
    });
  }

  function handleTacticalCtaClick(event: Event) {
    const target = event.target as Element | null;
    const trigger = target?.closest('button[data-tactical-cta]');

    if (!(trigger instanceof HTMLButtonElement) || trigger.disabled) return;

    document.dispatchEvent(
      new CustomEvent('open-diagnostic', {
        bubbles: true,
        cancelable: true,
      })
    );
  }

  if (root.dataset.diagnosticModalVisibilityBound !== 'true') {
    root.dataset.diagnosticModalVisibilityBound = 'true';
    initWhenVisible();
    document.addEventListener('astro:page-load', initWhenVisible);
  }

  if (root.dataset.diagnosticModalOpenBootstrapBound !== 'true') {
    root.dataset.diagnosticModalOpenBootstrapBound = 'true';
    document.addEventListener('open-diagnostic', ensureInitOnFirstOpen, { capture: true });
  }

  if (root.dataset.diagnosticModalCtaBound !== 'true') {
    root.dataset.diagnosticModalCtaBound = 'true';
    document.addEventListener('click', handleTacticalCtaClick);
  }
</script>
