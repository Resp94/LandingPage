---
// src/components/ui/DiagnosticModal.astro

import FormEmbed from './FormEmbed.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Formulário de Diagnóstico",
  description = "Complete os dados para prosseguirmos com a sua avaliação",
} = Astro.props;
---

<dialog
  id="diagnostic-modal"
  aria-labelledby="diagnostic-modal-title"
  aria-describedby="diagnostic-modal-description"
  aria-modal="true"
  role="dialog"
  class="backdrop:bg-zinc-950/80 backdrop:backdrop-blur-xl m-auto mx-auto p-0 max-w-xl w-[calc(100vw-2rem)] min-h-[400px] border border-zinc-800 bg-zinc-950 rounded-2xl shadow-2xl text-zinc-100 opacity-0 translate-y-2 open:opacity-100 open:translate-y-0 transition-all duration-300 ease-out motion-reduce:transition-none"
>
  <div class="relative w-full h-full p-6 sm:p-8 flex flex-col">
    <!-- Header -->
    <div class="mb-6 pr-8">
      <h2 id="diagnostic-modal-title" class="text-xl font-medium tracking-tight text-zinc-100 title-font">
        {title}
      </h2>
      <p id="diagnostic-modal-description" class="text-sm text-zinc-400 mt-1">
        {description}
      </p>
    </div>

    <!-- Close Button -->
    <button
      type="button"
      id="close-diagnostic-modal"
      aria-label="Fechar formulário de diagnóstico"
      class="absolute top-4 right-4 md:top-6 md:right-6 p-2 rounded-lg text-zinc-500 hover:text-zinc-100 hover:bg-zinc-800/50 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 z-10"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        class="h-5 w-5"
      >
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>

    <!-- Content Area for form and success steps -->
    <div class="flex-1 rounded-xl w-full h-full min-h-[500px] relative p-0 md:p-2 overflow-hidden flex items-stretch justify-center">
      
      <div id="form-view" class="absolute inset-0 transition-opacity duration-300 ease-out opacity-100 flex items-stretch justify-center w-full h-full z-10 bg-zinc-950">
        <FormEmbed />
      </div>

      <div id="success-view" role="status" aria-live="polite" class="absolute inset-x-0 inset-y-0 transition-opacity duration-300 ease-out opacity-0 hidden flex-col items-center justify-center text-center p-6 sm:p-8 z-20 bg-zinc-950 h-full w-full pointer-events-none">
        <div class="h-16 w-16 mb-6 rounded-full bg-emerald-500/10 flex items-center justify-center border border-emerald-500/20">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-emerald-500"
            aria-hidden="true"
          >
            <path d="M20 6 9 17l-5-5" />
          </svg>
        </div>
        
        <h3 class="text-2xl font-medium tracking-tight text-zinc-100 title-font mb-3">
          Analisando seu ecossistema...
        </h3>
        
        <p class="text-base text-zinc-400 max-w-sm mx-auto mb-8">
          Seu perfil foi enviado ao núcleo de Engenharia Aptus. Tempo de resposta projetado: 24h úteis.
        </p>

        <button
          type="button"
          id="success-close-btn"
          aria-label="Concluir e fechar"
          class="px-6 py-3 rounded-lg text-sm font-medium text-zinc-400 bg-transparent hover:bg-zinc-900 hover:text-zinc-100 border border-zinc-700/50 hover:border-zinc-700 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
        >
          Fechar
        </button>
      </div>
    </div>
  </div>
</dialog>

<script>
  const root = document.documentElement;
  const bootstrapOpenDetailKey = '__diagnosticModalBootstrap';

  async function initModal() {
    if (root.dataset.diagnosticModalInitDone === 'true') return;
    root.dataset.diagnosticModalInitDone = 'true';

    const { setupModalListener } = await import('../../scripts/modal');
    setupModalListener();
  }

  function scheduleIdleInit() {
    if (root.dataset.diagnosticModalIdleInitScheduled === 'true') return;
    root.dataset.diagnosticModalIdleInitScheduled = 'true';

    const runInit = () => {
      void initModal();
    };
    const requestIdle = globalThis.requestIdleCallback;

    if (typeof requestIdle === 'function') {
      requestIdle(runInit, { timeout: 2000 });
      return;
    }

    globalThis.setTimeout(runInit, 1200);
  }

  function initWhenVisible() {
    const dialog = document.getElementById('diagnostic-modal');
    if (!dialog) return;

    if (!('IntersectionObserver' in window)) {
      void initModal();
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          void initModal();
          observer.disconnect();
        }
      },
      {
        root: null,
        threshold: 0.01,
      }
    );

    observer.observe(dialog);
    scheduleIdleInit();
  }

  function ensureInitOnFirstOpen(event: Event) {
    const customEvent = event as CustomEvent<Record<string, unknown> | null>;
    const isBootstrapReplay =
      customEvent instanceof CustomEvent &&
      typeof customEvent.detail === 'object' &&
      customEvent.detail !== null &&
      customEvent.detail[bootstrapOpenDetailKey] === true;

    if (isBootstrapReplay) return;
    if (root.dataset.diagnosticModalInitDone === 'true') return;

    event.preventDefault();
    event.stopImmediatePropagation();

    void initModal().then(() => {
      document.dispatchEvent(
        new CustomEvent('open-diagnostic', {
          bubbles: true,
          cancelable: true,
          detail: { [bootstrapOpenDetailKey]: true },
        })
      );
    });
  }

  function handleTacticalCtaClick(event: Event) {
    const target = event.target as Element | null;
    const trigger = target?.closest('button[data-tactical-cta]');

    if (!(trigger instanceof HTMLButtonElement) || trigger.disabled) return;

    document.dispatchEvent(
      new CustomEvent('open-diagnostic', {
        bubbles: true,
        cancelable: true,
      })
    );
  }

  if (root.dataset.diagnosticModalVisibilityBound !== 'true') {
    root.dataset.diagnosticModalVisibilityBound = 'true';
    initWhenVisible();
    document.addEventListener('astro:page-load', initWhenVisible);
  }

  if (root.dataset.diagnosticModalOpenBootstrapBound !== 'true') {
    root.dataset.diagnosticModalOpenBootstrapBound = 'true';
    document.addEventListener('open-diagnostic', ensureInitOnFirstOpen, { capture: true });
  }

  if (root.dataset.diagnosticModalCtaBound !== 'true') {
    root.dataset.diagnosticModalCtaBound = 'true';
    document.addEventListener('click', handleTacticalCtaClick);
  }
</script>
