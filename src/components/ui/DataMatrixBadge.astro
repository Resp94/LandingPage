---
interface Props {
  label?: string;
  value: string | number;
}

const { label, value } = Astro.props;
---

<span class="inline-flex items-center gap-2 font-mono text-sm tracking-tight text-white/90">
  <span class="text-white/50 select-none">&gt;</span>
  {label && <span class="text-white/60">{label}:</span>}
  <span class="font-semibold">{value}</span>
</span>
