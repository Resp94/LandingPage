---
import { env as cloudflareEnv } from 'cloudflare:workers';
import { getGlobalSettings } from '../../lib/settings';

const settings = await getGlobalSettings();
const formId = cloudflareEnv?.TYPEFORM_FORM_ID || import.meta.env.TYPEFORM_FORM_ID || '';
---

<div class="form-embed-wrapper relative flex-1 min-h-[600px] w-full rounded-xl border border-[var(--color-border-subtle)] bg-surface-secondary/30 transition-all duration-300" data-form-id={formId}>
  <div class="form-skeleton absolute inset-0 z-10 flex flex-col gap-4 bg-surface-secondary/50 p-8 backdrop-blur-sm transition-opacity duration-300">
    <div class="mb-4 h-6 w-1/3 animate-pulse rounded bg-surface-tertiary"></div>
    <div class="h-10 w-full animate-pulse rounded bg-surface-tertiary"></div>
    <div class="h-10 w-5/6 animate-pulse rounded bg-surface-tertiary"></div>
    <div class="mt-4 h-24 w-full animate-pulse rounded bg-surface-tertiary"></div>
  </div>

  <noscript>
    <div class="absolute inset-0 z-20 flex flex-col items-center justify-center bg-surface-primary p-8 text-center text-sm text-[var(--color-text-secondary)]">
      <p class="mb-4 font-medium text-[var(--color-accent-data)]">JavaScript bloqueado ou indisponivel.</p>
      <a href={`mailto:${settings.contact_email}`} class="inline-flex h-9 items-center justify-center whitespace-nowrap rounded-md bg-accent/10 px-4 py-2 text-sm font-medium text-accent transition-colors hover:bg-accent/20 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent shadow-[0_0_15px_rgba(143,255,227,0.16)]">
        Entre em contato: {settings.contact_email}
      </a>
    </div>
  </noscript>

  <div class="form-fallback-cta hidden absolute inset-0 z-20 flex-col items-center justify-center bg-surface-primary p-8 text-center text-sm text-[var(--color-text-secondary)]">
    <p class="mb-4 font-medium text-[var(--color-accent-data)]">Nao foi possivel carregar o formulario interativo.</p>
    <p class="mb-6">Voce pode utilizar nosso canal alternativo de contato.</p>
    <a href={`mailto:${settings.contact_email}`} class="inline-flex h-9 items-center justify-center whitespace-nowrap rounded-md bg-accent/10 px-4 py-2 text-sm font-medium text-accent transition-colors hover:bg-accent/20 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent shadow-[0_0_15px_rgba(143,255,227,0.16)]">
      Entre em contato: {settings.contact_email}
    </a>
  </div>

  <div class="form-container relative z-0 w-full opacity-0 transition-opacity duration-500">
  </div>
</div>

<script>
  function initEmbeds() {
    const wrappers = document.querySelectorAll('.form-embed-wrapper');

    wrappers.forEach((wrapper) => {
      if (wrapper.getAttribute('data-init-done') === 'true') return;

      const formId = wrapper.getAttribute('data-form-id');
      const skeleton = wrapper.querySelector('.form-skeleton');
      const fallback = wrapper.querySelector('.form-fallback-cta');
      const container = wrapper.querySelector('.form-container');

      const showFallback = () => {
        if (skeleton) skeleton.classList.add('opacity-0', 'pointer-events-none');
        if (fallback) {
          fallback.classList.remove('hidden');
          fallback.classList.add('flex');
        }
      };

      if (!formId) {
        showFallback();
        return;
      }

      const loadForm = () => {
        if (wrapper.getAttribute('data-loaded') === 'true') return;
        wrapper.setAttribute('data-loaded', 'true');

        try {
          const silentFailureTimeoutMs = 8000;
          const iframe = document.createElement('iframe');
          iframe.src = `https://tally.so/embed/${formId}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1`;
          iframe.width = '100%';
          iframe.title = 'Diagnostic Form';
          iframe.allow = 'fullscreen';
          iframe.referrerPolicy = 'strict-origin-when-cross-origin';
          iframe.sandbox = 'allow-forms allow-scripts allow-same-origin allow-popups';
          iframe.className = 'w-full min-h-[400px] border-none';

          let iframeLoaded = false;
          const fallbackTimer = setTimeout(() => {
            if (!iframeLoaded) {
              showFallback();
            }
          }, silentFailureTimeoutMs);

          iframe.onload = () => {
            iframeLoaded = true;
            clearTimeout(fallbackTimer);
            setTimeout(() => {
              if (skeleton) skeleton.classList.add('opacity-0', 'pointer-events-none');
              if (container) container.classList.remove('opacity-0');
            }, 500);
          };

          iframe.onerror = () => {
            clearTimeout(fallbackTimer);
            showFallback();
          };

          if (container) {
            container.appendChild(iframe);
          }

          if (!document.querySelector('script[src="https://tally.so/widgets/embed.js"]')) {
            const tallyScript = document.createElement('script');
            tallyScript.src = 'https://tally.so/widgets/embed.js';
            tallyScript.async = true;
            document.body.appendChild(tallyScript);
          }
        } catch (error) {
          console.error('Form load error:', error);
          showFallback();
        }
      };

      const dialog = wrapper.closest('dialog');

      if (dialog) {
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.type === 'attributes' && mutation.attributeName === 'open') {
              if (dialog.hasAttribute('open')) {
                loadForm();
              }
            }
          });
        });
        observer.observe(dialog, { attributes: true });

        if (dialog.hasAttribute('open')) {
          loadForm();
        }
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            if (entries[0].isIntersecting) {
              loadForm();
              io.disconnect();
            }
          },
          { rootMargin: '100px' }
        );
        io.observe(wrapper);
      }

      wrapper.setAttribute('data-init-done', 'true');
    });
  }

  document.addEventListener('astro:page-load', initEmbeds);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEmbeds);
  } else {
    initEmbeds();
  }
</script>
