---
// src/components/ui/FormEmbed.astro
import { getGlobalSettings } from '../../lib/settings';

const settings = await getGlobalSettings();
const formId = import.meta.env.TYPEFORM_FORM_ID || '';
---

<div class="form-embed-wrapper relative w-full h-[500px] sm:h-[600px] flex-1 rounded-xl border border-surface-tertiary/50 overflow-hidden bg-surface-secondary/30" data-form-id={formId}>
  <!-- Skeleton Placeholder -->
  <div class="form-skeleton absolute inset-0 z-10 p-8 flex flex-col gap-4 bg-surface-secondary/50 backdrop-blur-sm transition-opacity duration-300">
    <div class="animate-pulse bg-surface-tertiary rounded w-1/3 h-6 mb-4"></div>
    <div class="animate-pulse bg-surface-tertiary rounded w-full h-10"></div>
    <div class="animate-pulse bg-surface-tertiary rounded w-5/6 h-10"></div>
    <div class="animate-pulse bg-surface-tertiary rounded w-full h-24 mt-4"></div>
  </div>

  <!-- Fallback if no JS -->
  <noscript>
    <div class="absolute inset-0 z-20 flex flex-col items-center justify-center p-8 text-center text-sm text-white/60 bg-surface-primary">
      <p class="mb-4 text-rose-400/80 font-medium">JavaScript bloqueado ou indisponível.</p>
      <a href={`mailto:${settings.contact_email}`} class="inline-flex h-9 items-center justify-center whitespace-nowrap rounded-md bg-accent/10 px-4 py-2 text-sm font-medium text-accent hover:bg-accent/20 transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent shadow-[0_0_15px_rgba(252,84,0,0.1)]">
        Entre em contato: {settings.contact_email}
      </a>
    </div>
  </noscript>

  <!-- Fallback if fetch/load fails -->
  <div class="form-fallback-cta hidden absolute inset-0 z-20 flex-col items-center justify-center p-8 text-center text-sm text-white/60 bg-surface-primary">
    <p class="mb-4 text-rose-400/80 font-medium">Não foi possível carregar o formulário interativo.</p>
    <p class="mb-6">Você pode utilizar nosso canal alternativo de contato.</p>
    <a href={`mailto:${settings.contact_email}`} class="inline-flex h-9 items-center justify-center whitespace-nowrap rounded-md bg-accent/10 px-4 py-2 text-sm font-medium text-accent hover:bg-accent/20 transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent shadow-[0_0_15px_rgba(252,84,0,0.1)]">
      Entre em contato: {settings.contact_email}
    </a>
  </div>

  <!-- Container for injected iframe -->
  <div class="form-container relative z-0 w-full h-full opacity-0 transition-opacity duration-500">
  </div>
</div>

<script>
  function initEmbeds() {
    const wrappers = document.querySelectorAll('.form-embed-wrapper');
    
    wrappers.forEach(wrapper => {
      if (wrapper.getAttribute('data-init-done') === 'true') return;
      
      const formId = wrapper.getAttribute('data-form-id');
      const skeleton = wrapper.querySelector('.form-skeleton');
      const fallback = wrapper.querySelector('.form-fallback-cta');
      const container = wrapper.querySelector('.form-container');
      
      const showFallback = () => {
        if (skeleton) skeleton.classList.add('opacity-0', 'pointer-events-none');
        if (fallback) {
          fallback.classList.remove('hidden');
          fallback.classList.add('flex');
        }
      };

      if (!formId) {
        // Test Resilience Support: If ID is missing, show fallback
        showFallback();
        return;
      }

      const loadForm = () => {
        if (wrapper.getAttribute('data-loaded') === 'true') return;
        wrapper.setAttribute('data-loaded', 'true');
        
        try {
          const silentFailureTimeoutMs = 8000;
          const iframe = document.createElement('iframe');
          // Using Tally embed script
          iframe.src = `https://tally.so/embed/${formId}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1`;
          iframe.width = '100%';
          iframe.height = '100%';
          iframe.title = 'Diagnostic Form';
          iframe.allow = 'fullscreen';
          iframe.referrerPolicy = 'strict-origin-when-cross-origin';
          iframe.sandbox = 'allow-forms allow-scripts allow-same-origin allow-popups';
          iframe.className = 'w-full h-full min-h-[400px] border-none';
          
          let iframeLoaded = false;
          const fallbackTimer = setTimeout(() => {
            if (!iframeLoaded) {
              showFallback();
            }
          }, silentFailureTimeoutMs);
          
          iframe.onload = () => {
            iframeLoaded = true;
            clearTimeout(fallbackTimer);
            // Delay slightly so form content can render inside iframe
            setTimeout(() => {
              if (skeleton) skeleton.classList.add('opacity-0', 'pointer-events-none');
              if (container) container.classList.remove('opacity-0');
            }, 500);
          };

          iframe.onerror = () => {
             clearTimeout(fallbackTimer);
             showFallback();
          };
          
          if (container) {
            container.appendChild(iframe);
          }

          // Add Tally resize script
          if (!document.querySelector('script[src="https://tally.so/widgets/embed.js"]')) {
            const tallyScript = document.createElement('script');
            tallyScript.src = 'https://tally.so/widgets/embed.js';
            tallyScript.async = true;
            document.body.appendChild(tallyScript);
          }
        } catch (error) {
          console.error("Form load error:", error);
          showFallback();
        }
      };

      const dialog = wrapper.closest('dialog');
      
      if (dialog) {
        // Observe dialog to load iframe only when open
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.type === 'attributes' && mutation.attributeName === 'open') {
              if (dialog.hasAttribute('open')) {
                loadForm();
              }
            }
          });
        });
        observer.observe(dialog, { attributes: true });
        
        // Load immediately if already open
        if (dialog.hasAttribute('open')) {
          loadForm();
        }
      } else {
        // Load via Intersection Observer if not in dialog
        const io = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting) {
            loadForm();
            io.disconnect();
          }
        }, { rootMargin: '100px' });
        io.observe(wrapper);
      }
      
      wrapper.setAttribute('data-init-done', 'true');
    });
  }

  // Handle Astro page transitions
  document.addEventListener('astro:page-load', initEmbeds);
  
  // Initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEmbeds);
  } else {
    initEmbeds();
  }
</script>
