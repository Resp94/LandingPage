---
// src/components/ui/TacticalCTA.astro
export interface Props {
  text?: string;
  ariaLabel?: string;
  fullWidth?: boolean;
  disabled?: boolean;
  class?: string;
}

const {
  text = "Agendar Auditoria Estratégica",
  ariaLabel = "Agendar Auditoria Estratégica",
  fullWidth = false,
  disabled = false,
  class: className = "",
} = Astro.props;
---

<button
  type="button"
  aria-label={ariaLabel}
  disabled={disabled}
  data-tactical-cta
  class:list={[
    'group relative inline-flex items-center justify-center gap-2',
    'px-8 py-4',
    'rounded-full',
    'font-sans uppercase font-medium tracking-wider text-sm',
    'border border-zinc-700 bg-transparent text-zinc-300',
    'transition-all duration-200 ease-out',
    'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950',
    'disabled:opacity-50 disabled:cursor-not-allowed',
    !disabled &&
      'hover:border-emerald-500/50 hover:bg-emerald-500/10 hover:text-emerald-400 hover:shadow-[inset_0_0_12px_rgba(16,185,129,0.1)]',
    fullWidth ? 'w-full' : 'w-auto',
    className,
  ]}
>
  <span class="relative z-10">{text}</span>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class:list={[
      'relative z-10 h-4 w-4 transition-transform duration-200 ease-out',
      !disabled && 'group-hover:translate-x-1',
    ]}
    aria-hidden="true"
  >
    <path d="M5 12h14" />
    <path d="m12 5 7 7-7 7" />
  </svg>
</button>

<script>
  function setupTacticalCTAs() {
    const buttons = document.querySelectorAll('button[data-tactical-cta]');

    buttons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      if (button.dataset.tacticalCtaBound === 'true') return;

      button.dataset.tacticalCtaBound = 'true';
      button.addEventListener('click', () => {
        if (button.disabled) return;

        button.dispatchEvent(
          new CustomEvent('open-diagnostic', {
            bubbles: true,
            cancelable: true,
          })
        );
      });
    });
  }

  // Set up on initial load
  setupTacticalCTAs();

  // Set up on view transitions if enabled
  document.addEventListener('astro:page-load', setupTacticalCTAs);
</script>
