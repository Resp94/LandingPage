---
export interface Props {
  text?: string;
  ariaLabel?: string;
  fullWidth?: boolean;
  disabled?: boolean;
  class?: string;
}

const {
  text = 'Agendar Auditoria Estrategica',
  ariaLabel = 'Agendar Auditoria Estrategica',
  fullWidth = false,
  disabled = false,
  class: className = '',
} = Astro.props;
---

<button
  type="button"
  aria-label={ariaLabel}
  disabled={disabled}
  data-tactical-cta
  class:list={[
    'group relative inline-flex items-center justify-center gap-2',
    'rounded-full border border-transparent px-8 py-4 text-sm font-sans font-bold tracking-wider uppercase md:py-3',
    'bg-[var(--color-accent)] text-[var(--color-surface-primary)]',
    'transition-all duration-300 ease-out',
    'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface-primary',
    'disabled:cursor-not-allowed disabled:opacity-50',
    !disabled && 'hover:scale-[1.02] hover:bg-[var(--color-accent-hover)] active:scale-95',
    fullWidth ? 'w-full' : 'w-auto',
    className,
  ]}
>
  <span class="relative z-10">{text}</span>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class:list={[
      'relative z-10 h-4 w-4 transition-transform duration-200 ease-out',
      !disabled && 'group-hover:translate-x-1',
    ]}
    aria-hidden="true"
  >
    <path d="M5 12h14" />
    <path d="m12 5 7 7-7 7" />
  </svg>
</button>
