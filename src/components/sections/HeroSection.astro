---
import TacticalCTA from '../ui/TacticalCTA.astro';
---

<section class="relative w-full overflow-hidden bg-[var(--color-surface-primary)] py-24 lg:py-32">
  <div class="pointer-events-none absolute inset-x-0 -top-[30%] mx-auto h-[600px] w-full max-w-4xl rounded-full bg-[var(--color-surface-tertiary)] opacity-30 blur-[120px]"></div>

  <div
    class="relative z-10 scroll-reveal mx-auto flex max-w-7xl flex-col items-start px-4 text-left sm:px-6 md:items-center md:text-center lg:px-8"
  >
    <header class="flex w-full flex-col items-start md:items-center">
      <h1 class="text-4xl font-bold tracking-tight text-[var(--color-text-primary)] sm:text-5xl md:text-6xl lg:text-7xl">
        Pare de Automatizar o Caos
      </h1>
      <p class="mt-8 max-w-2xl text-base leading-relaxed text-[var(--color-text-secondary)] sm:text-xl md:text-2xl">
        Engenharia Operacional para eliminar gargalos, padronizar processos e dar visibilidade real da sua operacao.
      </p>
    </header>

    <div class="mt-10 w-full md:w-auto">
      <TacticalCTA text="Agendar Auditoria" ariaLabel="Agendar Auditoria" class="w-full sm:w-auto" />
      <a
        href="#metodo-aptus"
        class="sr-only focus:not-sr-only focus:mt-3 focus:inline-flex focus:text-sm focus:text-[var(--color-accent)]"
      >
        Ir para a secao Metodo Aptus
      </a>
    </div>
  </div>
</section>
