---
import TacticalCTA from '../ui/TacticalCTA.astro';
// HeroSection.astro - Renderizado estaticamente (Zero-JS default)
// Otimizado para LCP rápido (above-the-fold) e sem dependências do cliente.
---

<section class="w-full py-24 lg:py-32">
  <div
    class="scroll-reveal mx-auto flex max-w-7xl flex-col items-start px-4 text-left sm:px-6 lg:px-8 md:items-center md:text-center"
  >
    <header class="flex w-full flex-col items-start md:items-center">
      <h1 class="text-3xl font-bold tracking-tight text-zinc-100 sm:text-5xl md:text-6xl lg:text-7xl">
        Pare de Automatizar o Caos
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-zinc-400 sm:text-xl lg:text-2xl">
        Engenharia Operacional para eliminar gargalos, padronizar processos e dar visibilidade real da sua
        operação.
      </p>
    </header>

    <div class="mt-8 w-full md:w-auto">
      <TacticalCTA class="w-full sm:w-auto" />
      <a
        href="#metodo-aptus"
        class="sr-only focus:not-sr-only focus:mt-3 focus:inline-flex focus:text-sm focus:text-emerald-400"
      >
        Ir para a seção Método Aptus
      </a>
    </div>
  </div>
</section>
