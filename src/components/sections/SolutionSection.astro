---
import DataMatrixBadge from '../ui/DataMatrixBadge.astro';

const steps = [
  {
    number: "01",
    title: "Auditoria",
    description: "Mapeamento as-is profundo dos seus gargalos operacionais e ineficiências técnicas.",
    metricLabel: "SLA Estimado",
    metricValue: "7 Dias",
    delayClass: ""
  },
  {
    number: "02",
    title: "Arquitetura",
    description: "Desenho da solução técnica ideal, com foco em automação, mitigação de riscos e escala.",
    metricLabel: "Output",
    metricValue: "Blueprint",
    delayClass: "delay-100"
  },
  {
    number: "03",
    title: "Deploy",
    description: "Refatoração e implementação cirúrgica das ferramentas padronizadas no blueprint.",
    metricLabel: "Tracking",
    metricValue: "Produção",
    delayClass: "delay-200"
  }
];
---

<section id="metodo-aptus" class="w-full py-24 lg:py-32 bg-zinc-950" aria-labelledby="solution-title">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="scroll-reveal mb-16 lg:mb-24 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
      <h2 id="solution-title" class="text-zinc-100 font-bold tracking-tight text-4xl lg:text-5xl max-w-2xl">
        Engenharia operacional.<br /> 
        <span class="text-zinc-400">O Método Aptus.</span>
      </h2>
      <p class="max-w-xl text-zinc-400 text-lg leading-relaxed">
        Uma abordagem metódica de desenvolvimento para trazer precisão ao seu backoffice e prepará-lo para escala.
      </p>
    </div>

    <!-- Layout responsivo com CSS Grid e divisores (blueprint blueprint) -->
    <ol class="grid grid-cols-1 lg:grid-cols-3 divide-y lg:divide-y-0 lg:divide-x divide-zinc-800/50 border border-zinc-800/50 bg-zinc-950/50 shadow-2xl">
      {steps.map((step) => (
        <li class={`scroll-reveal p-8 lg:p-12 flex flex-col justify-between ${step.delayClass}`}>
          <div>
            <div class="mb-8 border-b border-zinc-800/50 pb-6 w-16">
              <span class="font-mono text-4xl text-zinc-500 tracking-tighter">{step.number}</span>
            </div>
            <h3 class="text-2xl font-semibold text-zinc-100 mb-4">{step.title}</h3>
            <p class="text-zinc-400 leading-relaxed max-w-sm mb-12 line-clamp-3">
              {step.description}
            </p>
          </div>
          <div>
            <DataMatrixBadge label={step.metricLabel} value={step.metricValue} />
          </div>
        </li>
      ))}
    </ol>
    
  </div>
</section>
