---
import DataMatrixBadge from '../ui/DataMatrixBadge.astro';

const steps = [
  {
    number: '01',
    title: 'Auditoria',
    description: 'Mapeamento as-is profundo dos gargalos operacionais e ineficiencias tecnicas.',
    metricLabel: 'SLA Estimado',
    metricValue: '7 Dias',
    delayClass: '',
  },
  {
    number: '02',
    title: 'Arquitetura',
    description: 'Desenho da solucao tecnica ideal, com foco em automacao, mitigacao de riscos e escala.',
    metricLabel: 'Output',
    metricValue: 'Blueprint',
    delayClass: 'delay-100',
  },
  {
    number: '03',
    title: 'Deploy',
    description: 'Refatoracao e implementacao cirurgica das ferramentas padronizadas no blueprint.',
    metricLabel: 'Tracking',
    metricValue: 'Producao',
    delayClass: 'delay-200',
  },
];
---

<section
  id="metodo-aptus"
  class="w-full bg-[var(--color-surface-primary)] py-24 lg:py-32"
  aria-labelledby="solution-title"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="scroll-reveal mb-16 flex flex-col gap-6 lg:mb-24 lg:flex-row lg:items-end lg:justify-between">
      <h2 id="solution-title" class="max-w-2xl text-4xl font-semibold tracking-tight text-[var(--color-text-primary)] lg:text-5xl">
        Engenharia operacional.<br />
        <span class="text-[var(--color-text-secondary)]">O Metodo Aptus.</span>
      </h2>
      <p class="max-w-xl text-lg leading-relaxed text-[var(--color-text-secondary)]">
        Uma abordagem metodica de desenvolvimento para trazer precisao ao seu backoffice e prepara-lo para escala.
      </p>
    </div>

    <ol class="grid grid-cols-1 divide-y divide-[var(--color-border-subtle)] overflow-hidden rounded-3xl border border-[var(--color-border-subtle)] bg-[var(--color-surface-secondary)] shadow-xl lg:grid-cols-3 lg:divide-x lg:divide-y-0">
      {steps.map((step) => (
        <li class={`scroll-reveal flex flex-col justify-between p-8 lg:p-12 ${step.delayClass}`}>
          <div>
            <div class="mb-8 w-16 border-b border-[var(--color-grid-subtle)] pb-6">
              <span class="data-badge text-4xl text-[var(--color-text-meta)]">{step.number}</span>
            </div>
            <h3 class="mb-4 text-2xl font-semibold text-[var(--color-text-primary)]">{step.title}</h3>
            <p class="mb-12 line-clamp-3 max-w-sm leading-relaxed text-[var(--color-text-secondary)]">
              {step.description}
            </p>
          </div>
          <div>
            <DataMatrixBadge label={step.metricLabel} value={step.metricValue} variant="dark" />
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
