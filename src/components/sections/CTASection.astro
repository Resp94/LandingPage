---
import TacticalCTA from '../ui/TacticalCTA.astro';
---

<section
  id="auditoria"
  class="bg-[var(--color-surface-primary)] py-24 text-center lg:py-32"
  aria-labelledby="cta-title"
>
  <div class="scroll-reveal mx-auto w-full max-w-4xl px-4">
    <h2
      id="cta-title"
      class="text-4xl font-bold tracking-tight text-[var(--color-text-primary)] md:text-5xl lg:text-6xl"
    >
      Sua Operacao Merece Engenharia, <span class="text-[var(--color-text-secondary)]">Nao Remendos</span>
    </h2>

    <div class="mt-12 flex w-full justify-center">
      <TacticalCTA class="w-full shadow-2xl shadow-[var(--color-accent)]/20 sm:w-auto" />
    </div>

    <p class="mt-8 text-lg text-[var(--color-text-secondary)]">
      Analise sem compromisso. Sua operacao diagnosticada em ate 24h uteis.
    </p>
  </div>
</section>
