---
const faqs = [
  {
    question: 'Como funciona a Auditoria Estrategica?',
    answer:
      'A auditoria mapeia gargalos da operacao atual. Analisamos ferramentas, integracoes e processos manuais para entregar um blueprint tecnico claro.',
  },
  {
    question: 'A Aptus Flow desenvolve sistemas do zero?',
    answer:
      'O foco nao e criar sistemas do zero, mas conectar as ferramentas atuais e arquitetar fluxos ageis e escalaveis com foco em resultado operacional.',
  },
  {
    question: 'Quanto tempo dura a implementacao do Metodo Aptus?',
    answer:
      'A auditoria dura cerca de 7 dias. Depois da aprovacao do blueprint, o deploy varia de 2 a 6 semanas com entregas incrementais.',
  },
  {
    question: 'Minha equipe precisara de treinamento?',
    answer:
      'Sim. A entrega inclui documentacao e treinamento para remover dependencia de memoria e garantir operacao com confianca.',
  },
];
---

<section
  id="faq"
  class="w-full bg-[var(--color-surface-secondary)] py-24 pb-32"
  aria-labelledby="faq-title"
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="scroll-reveal mb-12 text-center md:mb-16">
      <h2 id="faq-title" class="text-3xl font-semibold tracking-tight text-[var(--color-text-primary)] md:text-4xl">
        Perguntas Frequentes
      </h2>
    </div>

    <div class="divide-y divide-[var(--color-border-subtle)] border-b border-[var(--color-border-subtle)]" data-faq-accordion>
      {faqs.map((faq, index) => (
        <div class="faq-item py-6">
          <button
            class="faq-button flex w-full items-center justify-between text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)]"
            aria-expanded="false"
            aria-controls={`faq-answer-${index}`}
            id={`faq-question-${index}`}
          >
            <span class="text-lg font-semibold text-[var(--color-text-primary)] transition-colors hover:text-[var(--color-accent-data)]">
              {faq.question}
            </span>
            <span class="ml-6 flex h-7 items-center">
              <svg
                class="faq-icon h-5 w-5 text-[var(--color-text-secondary)] transition-transform duration-300 ease-out"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M6 9l6 6 6-6"></path>
              </svg>
            </span>
          </button>

          <div
            id={`faq-answer-${index}`}
            class="faq-answer grid grid-rows-[0fr] overflow-hidden transition-all duration-300 ease-out"
            role="region"
            aria-labelledby={`faq-question-${index}`}
          >
            <div class="min-h-0">
              <p class="pr-12 pt-4 text-base leading-relaxed text-[var(--color-text-secondary)]">
                {faq.answer}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initFAQ() {
    const buttons = document.querySelectorAll('.faq-button');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const expanded = button.getAttribute('aria-expanded') === 'true';
        const ariaControls = button.getAttribute('aria-controls');
        const answer = document.getElementById(ariaControls!);
        const icon = button.querySelector('.faq-icon');

        if (expanded) {
          button.setAttribute('aria-expanded', 'false');
          answer?.classList.replace('grid-rows-[1fr]', 'grid-rows-[0fr]');
          icon?.classList.remove('rotate-180');
        } else {
          button.setAttribute('aria-expanded', 'true');
          answer?.classList.replace('grid-rows-[0fr]', 'grid-rows-[1fr]');
          icon?.classList.add('rotate-180');
        }
      });
    });
  }

  initFAQ();
  document.addEventListener('astro:page-load', initFAQ);
</script>
