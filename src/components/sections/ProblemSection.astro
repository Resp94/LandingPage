---
import DataMatrixBadge from '../ui/DataMatrixBadge.astro';
---

<section class="w-full bg-[var(--color-surface-light)] py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="scroll-reveal mb-16 lg:mb-24">
      <header class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <h2 class="max-w-2xl text-4xl font-bold tracking-tight text-[var(--color-surface-primary)] lg:text-5xl">
          Operar sem métricas claras é um <span class="text-[var(--color-accent-dark)]">voo cego.</span>
        </h2>
        <p class="line-clamp-3 max-w-3xl text-lg leading-relaxed text-[var(--color-surface-secondary)]">
          Processos manuais, escala linear por contratação e operações baseadas em memória. Sem sistemas eficientes, o caos operacional trava o seu crescimento e consome seus recursos.
        </p>
      </header>
    </div>

    <!-- Grid de Dores - Estilo Alívio Cognitivo (Light Mode) -->
    <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      <!-- Problema 1: Processos Manuais -->
      <li class="scroll-reveal flex flex-col gap-8 rounded-3xl border border-[var(--color-surface-secondary)]/10 bg-white p-8 lg:p-10">
        <div class="flex items-start justify-between">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[var(--color-surface-primary)]/5">
            <svg aria-hidden="true" focusable="false" class="h-6 w-6 text-[#E40C00]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <DataMatrixBadge value="ERR_MANUAL" variant="light" />
        </div>
        <div>
          <h3 class="mb-3 text-xl font-semibold text-[var(--color-surface-primary)]">Processos Manuais</h3>
          <p class="mb-6 max-w-sm leading-relaxed text-[var(--color-surface-tertiary)]/80">
            Tarefas repetitivas consumindo o tempo estratégico da sua equipe técnica e comercial.
          </p>
          <DataMatrixBadge label="Tempo Perdido" value="40%" variant="light" />
        </div>
      </li>

      <!-- Problema 2: Escala Linear -->
      <li class="scroll-reveal delay-100 flex flex-col gap-8 rounded-3xl border border-[var(--color-surface-secondary)]/10 bg-white p-8 lg:p-10">
        <div class="flex items-start justify-between">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[var(--color-surface-primary)]/5">
            <svg aria-hidden="true" focusable="false" class="h-6 w-6 text-[#E40C00]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <DataMatrixBadge value="SCL_LINEAR" variant="light" />
        </div>
        <div>
          <h3 class="mb-3 text-xl font-semibold text-[var(--color-surface-primary)]">Escala Linear</h3>
          <p class="mb-6 max-w-sm leading-relaxed text-[var(--color-surface-tertiary)]/80">
            O único jeito de atender mais clientes hoje é inflando a folha de pagamento com pessoal operacional.
          </p>
          <DataMatrixBadge label="Gargalo" value="Contratação" variant="light" />
        </div>
      </li>

      <!-- Problema 3: Dependência de Memória -->
      <li class="scroll-reveal delay-200 flex flex-col gap-8 rounded-3xl border border-[var(--color-surface-secondary)]/10 bg-white p-8 md:col-span-2 lg:col-span-1 lg:p-10">
        <div class="flex items-start justify-between">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[var(--color-surface-primary)]/5">
            <svg aria-hidden="true" focusable="false" class="h-6 w-6 text-[#E40C00]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <DataMatrixBadge value="MEM_DEP" variant="light" />
        </div>
        <div>
          <h3 class="mb-3 text-xl font-semibold text-[var(--color-surface-primary)]">Operação por Memória</h3>
          <p class="mb-6 max-w-sm leading-relaxed text-[var(--color-surface-tertiary)]/80">
            Procedimentos essenciais existem apenas na cabeça dos seus colaboradores mais experientes.
          </p>
          <DataMatrixBadge label="Risco Operacional" value="Crítico" variant="light" />
        </div>
      </li>
    </ul>
  </div>
</section>
